# =====================================================
# Aerowise — Variables de Entorno
# =====================================================
# Copia este archivo como .env y ajusta los valores.
# cp .env.example .env

# Django
DEBUG=True
SECRET_KEY=django-insecure-aerowise-dev-key-change-in-production-2026
ALLOWED_HOSTS=*

# Panel de Administración
PANEL_PASSWORD=aerowise2026

# Base de Datos (dejar vacío para usar SQLite en desarrollo)
# Para PostgreSQL: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Redis (para Celery)
REDIS_URL=redis://localhost:6379/0

# Email (solo en producción, en desarrollo se usa consola)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# CORS (solo en producción, separados por coma)
# CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
